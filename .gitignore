# OS files
.DS_Store
Thumbs.db

# Editor settings
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (keep examples only)
.env
.env.*
!.env.example

# Python backend
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# Node / React Native
node_modules/
.expo/
.expo-shared/
.metro-health-check*
*.tsbuildinfo

# React Native Android/iOS local/build artifacts
BlockApp/android/.gradle/
BlockApp/android/build/
BlockApp/android/app/build/
!BlockApp/android/app/build/
BlockApp/android/app/build/*
!BlockApp/android/app/build/outputs/
BlockApp/android/app/build/outputs/*
!BlockApp/android/app/build/outputs/apk/
BlockApp/android/app/build/outputs/apk/*
!BlockApp/android/app/build/outputs/apk/release/
BlockApp/android/app/build/outputs/apk/release/*
!BlockApp/android/app/build/outputs/apk/release/*.apk
BlockApp/android/local.properties
BlockApp/ios/Pods/
BlockApp/ios/build/
BlockApp/ios/DerivedData/
BlockApp/*.xcworkspace

# Mobile build outputs
*.apk
*.aab
*.ipa

# Allow committing release APK artifact
!BlockApp/android/app/build/outputs/apk/release/*.apk

# Android signing — NEVER commit these
*.keystore
!**/debug.keystore

# Test coverage
coverage/

# MDP
mdp_keystore.txt